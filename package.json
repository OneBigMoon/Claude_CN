{
  "name": "claude-desktop-cn",
  "version": "0.0.9",
  "description": "Claude Desktop 全部汉化补丁工具（macOS M5）",
  "type": "module",
  "private": false,
  "scripts": {
    "cn": "node scripts/claude-cn.mjs",
    "cn:status": "node scripts/claude-cn.mjs status",
    "menubar:build": "bash scripts/build-menubar-app.sh",
    "patch": "node scripts/patch-claude-cn.mjs --restart",
    "patch:no-restart": "node scripts/patch-claude-cn.mjs",
    "dist:dmg": "bash scripts/build-dmg.sh",
    "release:dmg": "bash scripts/release-dmg.sh"
  },
  "dependencies": {
    "@electron/asar": "^4.1.0"
  },
  "bin": {
    "claude-cn": "scripts/claude-cn.mjs"
  }
}
